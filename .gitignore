# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets
.env
*.key
*.pem
secrets.*

# Personal/sensitive local files
local_data/
browser_state/
*.sqlite
*.db
*.db-shm
*.db-wal

# Outputs can contain application-specific personal data
outputs/
!outputs/.gitkeep

# Profile backups contain personal data and are local only
data/backups/

# User-uploaded DOCX templates may contain personal contact details
data/local_templates/
data/uploads/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generated or personal documents — do not commit
*.pdf
*.rtf
# DOCX files may contain personal CV/CL templates with private contact details.
# The markdown templates in data/templates/ ARE committed; local .docx conversions are not.
*.docx
*.doc
